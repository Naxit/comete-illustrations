{
  "name": "@naxit/comete-illustrations",
  "version": "0.1.0-alpha.1",
  "description": "Comète illustration library — React components for empty states, onboarding, and contextual visuals",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./illustrations/*": {
      "types": "./dist/illustrations/*.d.ts",
      "import": "./dist/illustrations/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "figma:sync": "tsx scripts/fetch-illustrations.ts",
    "optimize": "tsx scripts/optimize-svg.ts",
    "generate": "tsx scripts/generate-components.ts",
    "pipeline": "pnpm figma:sync && pnpm optimize && pnpm generate && pnpm build",
    "build": "tsup",
    "clean": "rimraf dist",
    "prebuild": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "rimraf": "^6.1.3",
    "svgo": "^3.3.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": ">=22"
  },
  "license": "CC0-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/naxit/comete-illustrations.git"
  }
}
